# =============================================================================
# RecipeHub — Environment Variables
# Copy this file as .env and adjust values for your environment.
# =============================================================================

# ---------------------------------------------------------------------------
# MongoDB — root user for container initialization
# Used on first run to create the admin user.
# Example: admin
# ---------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=admin

# ---------------------------------------------------------------------------
# MongoDB — root user password
# Must match the credentials in MONGO_URI.
# Example: secure_password_123
# ---------------------------------------------------------------------------
MONGO_INITDB_ROOT_PASSWORD=secure_password_123

# ---------------------------------------------------------------------------
# API — port the Express server listens on inside the container
# Must match the port exposed in docker-compose.yml.
# Example: 4000
# ---------------------------------------------------------------------------
PORT=4000

# ---------------------------------------------------------------------------
# API — MongoDB connection URI
# Format: mongodb://USER:PASS@mongo:27017/DB?authSource=admin
# The hostname "mongo" is the docker-compose service name.
# Example: mongodb://admin:secure_password_123@mongo:27017/recipehub?authSource=admin
# ---------------------------------------------------------------------------
MONGO_URI=mongodb://admin:secure_password_123@mongo:27017/recipehub?authSource=admin

# ---------------------------------------------------------------------------
# API — secret key for signing and verifying JWT tokens
# Use a long, unique string in production.
# Example: your_super_secret_key_change_in_production
# ---------------------------------------------------------------------------
JWT_SECRET=your_super_secret_key_change_in_production
