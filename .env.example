# =============================================================================
# RecipeHub — Variables de Entorno
# Copia este archivo como .env y ajusta los valores según tu entorno.
# =============================================================================

# ---------------------------------------------------------------------------
# MongoDB — usuario root para la inicialización del contenedor
# Se usa en la primera ejecución para crear el usuario administrador.
# Ejemplo: admin
# ---------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=admin

# ---------------------------------------------------------------------------
# MongoDB — contraseña del usuario root
# Debe coincidir con las credenciales en MONGO_URI.
# Ejemplo: secure_password_123
# ---------------------------------------------------------------------------
MONGO_INITDB_ROOT_PASSWORD=secure_password_123

# ---------------------------------------------------------------------------
# API — puerto donde corre el servidor Express dentro del contenedor
# Debe coincidir con el puerto expuesto en docker-compose.yml.
# Ejemplo: 4000
# ---------------------------------------------------------------------------
PORT=4000

# ---------------------------------------------------------------------------
# API — URI de conexión a MongoDB
# Formato: mongodb://USER:PASS@mongo:27017/DB?authSource=admin
# El hostname "mongo" es el nombre del servicio en docker-compose.
# Ejemplo: mongodb://admin:secure_password_123@mongo:27017/recipehub?authSource=admin
# ---------------------------------------------------------------------------
MONGO_URI=mongodb://admin:secure_password_123@mongo:27017/recipehub?authSource=admin

# ---------------------------------------------------------------------------
# API — clave secreta para firmar y verificar tokens JWT
# Debe ser una cadena larga y única en producción.
# Ejemplo: your_super_secret_key_change_in_production
# ---------------------------------------------------------------------------
JWT_SECRET=your_super_secret_key_change_in_production
